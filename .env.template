# .env file template for Ash Bot
# Copy this file to .env and fill in your actual values

# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here

# Claude API Configuration
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_API_KEY=your_claude_api_key_here

# Channel Configuration
RESOURCES_CHANNEL_ID=your_resources_channel_id_here
CRISIS_RESPONSE_CHANNEL_ID=your_crisis_response_channel_id_here

# Channel restrictions - comma-separated list of channel IDs where Ash can respond
# Leave empty for no restrictions (responds in all channels)
ALLOWED_CHANNELS=channel_id_1,channel_id_2,channel_id_3

# Staff and Crisis Team Configuration
STAFF_PING_USER=staff_user_id_here
CRISIS_RESPONSE_ROLE_ID=crisis_team_role_id_here

# Display Names for Bot Responses (what users see in messages)
RESOURCES_CHANNEL_NAME=resources
CRISIS_RESPONSE_ROLE_NAME=CrisisResponse
STAFF_PING_NAME=StaffUserName

# Learning System
ENABLE_LEARNING_SYSTEM=true
LEARNING_CONFIDENCE_THRESHOLD=0.6
MAX_LEARNING_ADJUSTMENTS_PER_DAY=50

# Replace with your AI rig's actual IP address
NLP_SERVICE_HOST=10.20.30.16
NLP_SERVICE_PORT=8881
REQUEST_TIMEOUT=30

# Optional Bot Settings
LOG_LEVEL=INFO
MAX_DAILY_CALLS=1000
RATE_LIMIT_PER_USER=10

# Conversation Isolation Configuration
# Enable mention/ping requirement for conversation follow-ups
CONVERSATION_REQUIRES_MENTION=true

# Comma-separated list of trigger phrases that will continue conversations
# Users can say any of these to get Ash to respond during their 5-minute window
CONVERSATION_TRIGGER_PHRASES=ash,hey ash,ash help,@ash

# Allow natural conversation starters like "I'm still", "But I", etc.
# Set to false for stricter mention-only requirement
CONVERSATION_ALLOW_STARTERS=true

# Include instructions in crisis responses about how to continue conversations
# Set to false to send responses without continuation instructions
CONVERSATION_SETUP_INSTRUCTIONS=true

# Crisis override settings - which crisis levels can interrupt ongoing conversations
# Options: none, low, medium, high (comma-separated)
CRISIS_OVERRIDE_LEVELS=medium,high

# Log when users try to continue conversations without proper triggers
# Helpful for monitoring and debugging the isolation system
CONVERSATION_LOG_ATTEMPTS=true

# How long conversations stay active (in seconds) - 300 = 5 minutes
CONVERSATION_TIMEOUT=300

# Example filled out:
# DISCORD_TOKEN=MTAyNzM4OTQyNzUxNjQzMjQ2Ng.GXxKzQ.abc123def456...
# GUILD_ID=123456789012345678
# CLAUDE_API_KEY=sk-ant-api03-abc123def456...
# RESOURCES_CHANNEL_ID=987654321098765432
# CRISIS_RESPONSE_CHANNEL_ID=876543210987654321
# ALLOWED_CHANNELS=123456789,987654321,555666777
# STAFF_PING_USER=111222333444555666
# CRISIS_RESPONSE_ROLE_ID=999888777666555444
# CONVERSATION_TRIGGER_PHRASES=ash,hey ash,ash help,@ash,ash can you